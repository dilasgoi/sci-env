#!/usr/bin/env bash
#==============================================================================
# sci-env runtime loader (auto-generated; do not edit by hand)
#
# Deployment
#   System-wide (NFS-shared install, recommended for clusters):
#       sudo install -m 0644 @SCICOMP_PREFIX@/init.sh /etc/profile.d/scicomp.sh
#   Per-user (single-host install under $HOME):
#       source @SCICOMP_PREFIX@/init.sh   # already wired into ~/.bashrc by the installer
#
# At every login this script:
#   1. Detects OS family + major from /etc/os-release.
#   2. Resolves the host microarchitecture:
#        a) Built-in heuristics for CPUs archspec doesn't recognise yet
#           (currently: Intel Sierra Forest, which archspec <= 0.2.6 misreads
#           as 'skylake' because it has no AVX-512).
#        b) archspec auto-detection (preferred path for known CPUs).
#        c) uname -m fallback.
#   3. Auto-creates the host's <arch>/ slot directory if missing (idempotent;
#      silent on read-only mounts).
#   4. Composes MODULEPATH as: <host_arch>/modules/all : <compatible ancestor
#      slots that exist> : <common>/modules/all. So a node sees its own builds
#      first and falls back to compatible older slots before common tools.
#   5. Configures EASYBUILD_* to write into the host's <arch>/ slot.
#
# This loader configures *where* EasyBuild reads/writes (routing). It does
# NOT set compiler optimization flags. EasyBuild handles -march/-mtune via
# its own archspec integration. If you want to override flags for a specific
# build, pass `eb --optarch=...` at invocation time.
#==============================================================================

# Baked-in at install time
SCICOMP_PREFIX="@SCICOMP_PREFIX@"
SCICOMP_LUA_VERSION="@LUA_VERSION@"
SCICOMP_LMOD_VERSION="@LMOD_VERSION@"

_scicomp_detect_os() {
    SCICOMP_OS_ID=""
    SCICOMP_OS_MAJOR=""
    [ -r /etc/os-release ] || return
    # Sourced inside subshells so /etc/os-release's other fields (NAME,
    # PRETTY_NAME, BUG_REPORT_URL, etc.) don't leak into the user's shell.
    SCICOMP_OS_ID=$(
        # shellcheck disable=SC1091
        . /etc/os-release
        echo "${ID:-}" | tr '[:upper:]' '[:lower:]'
    )
    SCICOMP_OS_MAJOR=$(
        # shellcheck disable=SC1091
        . /etc/os-release
        echo "${VERSION_ID:-}"
    )
    SCICOMP_OS_MAJOR="${SCICOMP_OS_MAJOR%%.*}"
}

# Heuristic for CPUs archspec misses. Intel Sierra Forest (Xeon 6 E-core
# server, e.g. 6740E) is identified by: GenuineIntel Xeon brand string,
# AVX-VNNI present, AVX-512 absent. This combination is unique to Sierra
# Forest among current server CPUs and stays robust until archspec ships
# native support.
_scicomp_is_sierraforest_cpu() {
    [ -r /proc/cpuinfo ] || return 1
    grep -q '^vendor_id.*GenuineIntel' /proc/cpuinfo || return 1
    grep -q '^model name.*Xeon'        /proc/cpuinfo || return 1
    grep -qw 'avx_vnni'                /proc/cpuinfo || return 1
    ! grep -qw 'avx512f'               /proc/cpuinfo
}

# Print arch candidates: host first, then ancestors (compatibility chain).
_scicomp_arch_candidates() {
    local py="${SCICOMP_PREFIX}/tools/archspec/bin/python"

    # 1. Sierra Forest fingerprint (archspec <= 0.2.6 misreads as skylake).
    if _scicomp_is_sierraforest_cpu; then
        cat <<'EOF'
sierraforest
x86_64_v3
broadwell
haswell
ivybridge
x86_64_v2
sandybridge
westmere
nehalem
core2
x86_64
EOF
        return
    fi

    # 2. archspec auto-detection (preferred path for known CPUs).
    if [ -x "${py}" ]; then
        "${py}" -c "import archspec.cpu as c
h = c.host()
print(h.name)
for a in h.ancestors:
    print(a.name)" 2>/dev/null && return
    fi

    # 3. archspec from PATH (single line, no ancestors).
    if command -v archspec >/dev/null 2>&1; then
        archspec cpu 2>/dev/null && return
    fi

    # 4. Last-resort fallback.
    uname -m
}

_scicomp_init() {
    _scicomp_detect_os
    [ -z "${SCICOMP_OS_ID}" ]    && return 0
    [ -z "${SCICOMP_OS_MAJOR}" ] && return 0

    local os_root="${SCICOMP_PREFIX}/builds/${SCICOMP_OS_ID}/${SCICOMP_OS_MAJOR}"
    local common_dir="${os_root}/common"
    [ -d "${common_dir}" ] || return 0

    # Resolve candidate list and treat the first entry as the host arch.
    local candidates host_arch=""
    candidates=$(_scicomp_arch_candidates)
    host_arch=$(echo "${candidates}" | head -n 1)
    [ -z "${host_arch}" ] && return 0

    # Auto-create the host's slot so 'eb' has a place to write on this node.
    # Idempotent; truly silent on read-only mounts (|| true keeps the loader
    # from aborting if it's sourced from a script with `set -e`).
    mkdir -p "${os_root}/${host_arch}/software" \
             "${os_root}/${host_arch}/modules/all" \
             "${os_root}/${host_arch}/build" 2>/dev/null || true

    # Lua (always common)
    export PATH="${common_dir}/software/Lua/${SCICOMP_LUA_VERSION}/bin${PATH:+:${PATH}}"
    export LD_LIBRARY_PATH="${common_dir}/software/Lua/${SCICOMP_LUA_VERSION}/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"

    # Lmod
    local lmod_init="${common_dir}/software/Lmod/${SCICOMP_LMOD_VERSION}/lmod/lmod/init/profile"
    if [ -r "${lmod_init}" ]; then
        # shellcheck disable=SC1090
        . "${lmod_init}"
    fi

    # MODULEPATH: host slot first, then existing ancestor slots, then common.
    local slot_paths="" arch
    for arch in ${candidates}; do
        if [ -d "${os_root}/${arch}/modules/all" ]; then
            slot_paths="${slot_paths:+${slot_paths}:}${os_root}/${arch}/modules/all"
        fi
    done
    local mp="${slot_paths}${slot_paths:+:}${common_dir}/modules/all"
    export MODULEPATH="${mp}${MODULEPATH:+:${MODULEPATH}}"

    # EasyBuild: routing only (where to read/write). Optimization flags
    # (-march/-mtune) are EB's responsibility via its own archspec.
    export EASYBUILD_PREFIX="${os_root}/${host_arch}"
    export EASYBUILD_INSTALLPATH="${os_root}/${host_arch}"
    export EASYBUILD_INSTALLPATH_MODULES="${os_root}/${host_arch}/modules"
    export EASYBUILD_SOURCEPATH="${SCICOMP_PREFIX}/src"
    export EASYBUILD_BUILDPATH="${os_root}/${host_arch}/build"
    export EASYBUILD_MODULES_TOOL="Lmod"

    export SCICOMP_ACTIVE_ARCH="${host_arch}"
    export SCICOMP_OS_ID SCICOMP_OS_MAJOR
}

_scicomp_init
unset -f _scicomp_init _scicomp_detect_os _scicomp_arch_candidates _scicomp_is_sierraforest_cpu
